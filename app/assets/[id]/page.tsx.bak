'use client';

import { useState, useEffect } from 'react';
import { useRouter, useParams } from 'next/navigation';
import { DashboardNav } from '@/components/DashboardNav';
import Link from 'next/link';
import { ASSET_CATEGORIES, ASSET_STATUSES } from '@/lib/constants/assetConstants';
import { QuickConnectButton } from '@/components/remote/QuickConnectButton';

interface Asset {
    id: string;
    assetType: string; // NEW
    name: string;
    category: string;
    manufacturer?: string;
    model?: string;
    serialNumber?: string;
    status: string;
    location?: string;
    description?: string;
    purchaseDate?: string;
    purchaseCost?: number;
    warrantyUntil?: string;
    tags: string[];
    qrCode?: string;  // Base64 QR code data URL
    assignedTo?: {
        id: string;
        name: string;
        email: string;
        role: string;
    };
    // NEW: Type-specific relations
    hardwareAsset?: {
        processor?: string;
        ram?: number;
        storage?: number;
        osVersion?: string;
        macAddress?: string;
        ipAddress?: string;
    };
    softwareAsset?: {
        version?: string;
        vendor?: string;
        licenseKey?: string;
        licenseType?: string;
        seatCount?: number;
        seatsUsed?: number;
        subscriptionTier?: string;
        monthlyRecurringCost?: number;
        renewalDate?: string;
        autoRenew?: boolean;
        host?: string;
        hostType?: string;
        url?: string;
        sslExpiry?: string;
        connectionString?: string;
        databaseSize?: number;
        installedOn?: string[];
    };
    assignmentHistory: Array<{
        id: string;
        assignedAt: string;
        unassignedAt?: string;
        notes?: string;
        user: {
            id: string;
            name: string;
            email: string;
        };
    }>;
    remoteSessions: Array<{
        id: string;
        status: string;
        startedAt: string;
        endedAt?: string;
        user: {
            id: string;
            name: string;
            email: string;
        };
    }>;
    createdAt: string;
    updatedAt: string;
}

export default function AssetDetailPage() {
    const params = useParams();
    const router = useRouter();
    const [asset, setAsset] = useState<Asset | null>(null);
    const [loading, setLoading] = useState(true);
    const [showDeleteModal, setShowDeleteModal] = useState(false);
    const [deleting, setDeleting] = useState(false);

    useEffect(() => {
        if (params.id) {
            fetchAsset();
        }
    }, [params.id]);

    const fetchAsset = async () => {
        try {
            const response = await fetch(`/api/assets/${params.id}`);
            if (!response.ok) throw new Error('Failed to fetch asset');
            const data = await response.json();
            setAsset(data);
        } catch (error) {
            console.error('Error fetching asset:', error);
        } finally {
            setLoading(false);
        }
    };

    const handleDelete = async () => {
        setDeleting(true);
        try {
            const response = await fetch(`/api/assets/${params.id}`, {
                method: 'DELETE',
            });
            if (!response.ok) throw new Error('Failed to delete asset');
            router.push('/assets');
        } catch (error) {
            console.error('Error deleting asset:', error);
            alert('Failed to delete asset');
        } finally {
            setDeleting(false);
        }
    };

    const getStatusColor = (status: string) => {
        switch (status) {
            case 'AVAILABLE':
                return 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200';
            case 'ASSIGNED':
                return 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200';
            case 'MAINTENANCE':
                return 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200';
            case 'RETIRED':
                return 'bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200';
            case 'LOST':
                return 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200';
            default:
                return 'bg-gray-100 text-gray-800 dark:bg-gray-900 dark:text-gray-200';
        }
    };

    const getCategoryLabel = (category: string) => {
        const cat = Object.values(ASSET_CATEGORIES).find(c => c.value === category);
        return cat?.label || category;
    };

    const getStatusLabel = (status: string) => {
        const stat = Object.values(ASSET_STATUSES).find(s => s.value === status);
        return stat?.label || status;
    };

    const downloadQRCode = () => {
        if (!asset?.qrCode) return;
        const link = document.createElement('a');
        link.href = asset.qrCode;
        link.download = `${asset.name}-QR.png`;
        link.click();
    };

    if (loading) {
        return (
            <div className="min-h-screen bg-background">
                <DashboardNav />
                <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                    <div className="flex items-center justify-center py-12">
                        <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
                    </div>
                </div>
            </div>
        );
    }

    if (!asset) {
        return (
            <div className="min-h-screen bg-background">
                <DashboardNav />
                <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                    <div className="card text-center py-12">
                        <h3 className="text-lg font-medium text-foreground">Asset not found</h3>
                        <Link href="/assets" className="btn-primary mt-4  inline-block">
                            Back to Assets
                        </Link>
                    </div>
                </div>
            </div>
        );
    }

    return (
        <div className="min-h-screen bg-background">
            <DashboardNav />

            <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
                {/* Header */}
                <div className="flex items-center justify-between mb-8">
                    <div className="flex items-center gap-4">
                        <Link
                            href="/assets"
                            className="text-muted-foreground hover:text-foreground transition-colors"
                        >
                            <svg
                                className="w-6 h-6"
                                fill="none"
                                strokeLinecap="round"
                                strokeLinejoin="round"
                                strokeWidth="2"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path d="M15 19l-7-7 7-7" />
                            </svg>
                        </Link>
                        <div>
                            <h1 className="text-3xl font-bold text-foreground">{asset.name}</h1>
                            <p className="text-muted-foreground mt-1">{getCategoryLabel(asset.category)}</p>
                        </div>
                        <span className={`badge ${getStatusColor(asset.status)}`}>
                            {getStatusLabel(asset.status)}
                        </span>
                    </div>
                    <div className="flex items-center gap-2">
                        <QuickConnectButton assetId={asset.id} assetName={asset.name} />
                        <Link
                            href={`/assets/${asset.id}/edit`}
                            className="btn-secondary"
                        >
                            Edit
                        </Link>
                        <button
                            onClick={() => setShowDeleteModal(true)}
                            className="btn bg-red-600 text-white hover:bg-red-700"
                        >
                            Delete
                        </button>
                    </div>
                </div>

                <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    {/* Main Info */}
                    <div className="lg:col-span-2 space-y-6">
                        {/* Details Card */}
                        <div className="card">
                            <h2 className="text-xl font-semibold text-foreground mb-4">Details</h2>
                            <dl className="grid grid-cols-2 gap-4">
                                <div>
                                    <dt className="text-sm font-medium text-muted-foreground">Manufacturer</dt>
                                    <dd className="mt-1 text-sm text-foreground">
                                        {asset.manufacturer || '-'}
                                    </dd>
                                </div>
                                <div>
                                    <dt className="text-sm font-medium text-muted-foreground">Model</dt>
                                    <dd className="mt-1 text-sm text-foreground">{asset.model || '-'}</dd>
                                </div>
                                <div>
                                    <dt className="text-sm font-medium text-muted-foreground">Serial Number</dt>
                                    <dd className="mt-1 text-sm text-foreground font-mono">
                                        {asset.serialNumber || '-'}
                                    </dd>
                                </div>
                                <div>
                                    <dt className="text-sm font-medium text-muted-foreground">Location</dt>
                                    <dd className="mt-1 text-sm text-foreground">{asset.location || '-'}</dd>
                                </div>
                                {asset.purchaseDate && (
                                    <div>
                                        <dt className="text-sm font-medium text-muted-foreground">Purchase Date</dt>
                                        <dd className="mt-1 text-sm text-foreground">
                                            {new Date(asset.purchaseDate).toLocaleDateString()}
                                        </dd>
                                    </div>
                                )}
                                {asset.purchaseCost && (
                                    <div>
                                        <dt className="text-sm font-medium text-muted-foreground">Purchase Cost</dt>
                                        <dd className="mt-1 text-sm text-foreground">
                                            ${asset.purchaseCost.toLocaleString()}
                                        </dd>
                                    </div>
                                )}
                                {asset.warrantyUntil && (
                                    <div>
                                        <dt className="text-sm font-medium text-muted-foreground">Warranty Until</dt>
                                        <dd className="mt-1 text-sm text-foreground">
                                            {new Date(asset.warrantyUntil).toLocaleDateString()}
                                        </dd>
                                    </div>
                                )}
                                {asset.description && (
                                    <div className="col-span-2">
                                        <dt className="text-sm font-medium text-muted-foreground">Description</dt>
                                        <dd className="mt-1 text-sm text-foreground">{asset.description}</dd>
                                    </div>
                                )}
                            </dl>
                        </div>

                        {/* Hardware-Specific Details */}
                        {asset.assetType === 'HARDWARE' && asset.hardwareAsset && (
                            <div className="card">
                                <h2 className="text-xl font-semibold text-foreground mb-4">
                                    ⚙️ Technical Specifications
                                </h2>
                                <dl className="grid grid-cols-2 gap-4">
                                    {asset.hardwareAsset.processor && (
                                        <div>
                                            <dt className="text-sm font-medium text-muted-foreground">Processor</dt>
                                            <dd className="mt-1 text-sm text-foreground">
                                                {asset.hardwareAsset.processor}
                                            </dd>
                                        </div>
                                    )}
                                    {asset.hardwareAsset.ram && (
                                        <div>
                                            <dt className="text-sm font-medium text-muted-foreground">RAM</dt>
                                            <dd className="mt-1 text-sm text-foreground">
                                                {asset.hardwareAsset.ram} GB
                                            </dd>
                                        </div>
                                    )}
                                    {asset.hardwareAsset.storage && (
                                        <div>
                                            <dt className="text-sm font-medium text-muted-foreground">Storage</dt>
                                            <dd className="mt-1 text-sm text-foreground">
                                                {asset.hardwareAsset.storage} GB
                                            </dd>
                                        </div>
                                    )}
                                    {asset.hardwareAsset.osVersion && (
                                        <div>
                                            <dt className="text-sm font-medium text-muted-foreground">OS Version</dt>
                                            <dd className="mt-1 text-sm text-foreground">
                                                {asset.hardwareAsset.osVersion}
                                            </dd>
                                        </div>
                                    )}
                                    {asset.hardwareAsset.macAddress && (
                                        <div>
                                            <dt className="text-sm font-medium text-muted-foreground">MAC Address</dt>
                                            <dd className="mt-1 text-sm text-foreground font-mono">
                                                {asset.hardwareAsset.macAddress}
                                            </dd>
                                        </div>
                                    )}
                                    {asset.hardwareAsset.ipAddress && (
                                        <div>
                                            <dt className="text-sm font-medium text-muted-foreground">IP Address</dt>
                                            <dd className="mt-1 text-sm text-foreground font-mono">
                                                {asset.hardwareAsset.ipAddress}
                                            </dd>
                                        </div>
                                    )}
                                </dl>
                            </div>
                        )}

                        {/* Software-Specific Details */}
                        {asset.assetType === 'SOFTWARE' && asset.softwareAsset && (
                            <>
                                {/* License Information */}
                                <div className="card">
                                    <h2 className="text-xl font-semibold text-foreground mb-4">
                                        🔑 License Information
                                    </h2>
                                    <dl className="grid grid-cols-2 gap-4">
                                        {asset.softwareAsset.version && (
                                            <div>
                                                <dt className="text-sm font-medium text-muted-foreground">Version</dt>
                                                <dd className="mt-1 text-sm text-foreground">
                                                    {asset.softwareAsset.version}
                                                </dd>
                                            </div>
                                        )}
                                        {asset.softwareAsset.vendor && (
                                            <div>
                                                <dt className="text-sm font-medium text-muted-foreground">Vendor</dt>
                                                <dd className="mt-1 text-sm text-foreground">
                                                    {asset.softwareAsset.vendor}
                                                </dd>
                                            </div>
                                        )}
                                        {asset.softwareAsset.licenseType && (
                                            <div>
                                                <dt className="text-sm font-medium text-muted-foreground">License Type</dt>
                                                <dd className="mt-1 text-sm text-foreground">
                                                    {asset.softwareAsset.licenseType}
                                                </dd>
                                            </div>
                                        )}
                                        {asset.softwareAsset.licenseKey && (
                                            <div>
                                                <dt className="text-sm font-medium text-muted-foreground">License Key</dt>
                                                <dd className="mt-1 text-sm text-foreground font-mono">
                                                    {asset.softwareAsset.licenseKey}
                                                </dd>
                                            </div>
                                        )}
                                        {asset.softwareAsset.seatCount && (
                                            <div>
                                                <dt className="text-sm font-medium text-muted-foreground">Seats</dt>
                                                <dd className="mt-1 text-sm text-foreground">
                                                    {asset.softwareAsset.seatsUsed || 0} / {asset.softwareAsset.seatCount}
                                                    <span className="text-xs text-muted-foreground ml-2">
                                                        ({Math.round(((asset.softwareAsset.seatsUsed || 0) / asset.softwareAsset.seatCount) * 100)}% used)
                                                    </span>
                                                </dd>
                                            </div>
                                        )}
                                    </dl>
                                </div>

                                {/* SaaS/Subscription Info */}
                                {(asset.softwareAsset.subscriptionTier || asset.softwareAsset.monthlyRecurringCost || asset.softwareAsset.renewalDate) && (
                                    <div className="card">
                                        <h2 className="text-xl font-semibold text-foreground mb-4">
                                            ☁️ Subscription Details
                                        </h2>
                                        <dl className="grid grid-cols-2 gap-4">
                                            {asset.softwareAsset.subscriptionTier && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">Tier</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        {asset.softwareAsset.subscriptionTier}
                                                    </dd>
                                                </div>
                                            )}
                                            {asset.softwareAsset.monthlyRecurringCost && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">Monthly Cost</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        ${asset.softwareAsset.monthlyRecurringCost.toFixed(2)}
                                                    </dd>
                                                </div>
                                            )}
                                            {asset.softwareAsset.renewalDate && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">Renewal Date</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        {new Date(asset.softwareAsset.renewalDate).toLocaleDateString()}
                                                    </dd>
                                                </div>
                                            )}
                                            <div>
                                                <dt className="text-sm font-medium text-muted-foreground">Auto Renew</dt>
                                                <dd className="mt-1 text-sm text-foreground">
                                                    {asset.softwareAsset.autoRenew ? '✓ Yes' : '✗ No'}
                                                </dd>
                                            </div>
                                        </dl>
                                    </div>
                                )}

                                {/* Hosting Information */}
                                {(asset.softwareAsset.host || asset.softwareAsset.url) && (
                                    <div className="card">
                                        <h2 className="text-xl font-semibold text-foreground mb-4">
                                            🏢 Hosting Information
                                        </h2>
                                        <dl className="grid grid-cols-2 gap-4">
                                            {asset.softwareAsset.hostType && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">Host Type</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        {asset.softwareAsset.hostType}
                                                    </dd>
                                                </div>
                                            )}
                                            {asset.softwareAsset.host && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">Host</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        {asset.softwareAsset.host}
                                                    </dd>
                                                </div>
                                            )}
                                            {asset.softwareAsset.url && (
                                                <div className="col-span-2">
                                                    <dt className="text-sm font-medium text-muted-foreground">URL</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        <a
                                                            href={asset.softwareAsset.url}
                                                            target="_blank"
                                                            rel="noopener noreferrer"
                                                            className="text-primary hover:underline"
                                                        >
                                                            {asset.softwareAsset.url}
                                                        </a>
                                                    </dd>
                                                </div>
                                            )}
                                            {asset.softwareAsset.sslExpiry && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">SSL Expiry</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        {new Date(asset.softwareAsset.sslExpiry).toLocaleDateString()}
                                                    </dd>
                                                </div>
                                            )}
                                            {asset.softwareAsset.databaseSize && (
                                                <div>
                                                    <dt className="text-sm font-medium text-muted-foreground">Database Size</dt>
                                                    <dd className="mt-1 text-sm text-foreground">
                                                        {asset.softwareAsset.databaseSize} MB
                                                    </dd>
                                                </div>
                                            )}
                                        </dl>
                                    </div>
                                )}
                            </>
                        )}
                        {/* Assignment History */}
                        {asset.assignmentHistory && asset.assignmentHistory.length > 0 && (
                            <div className="card">
                                <h2 className="text-xl font-semibold text-foreground mb-4">
                                    Assignment History
                                </h2>
                                <div className="space-y-4">
                                    {asset.assignmentHistory.map((assignment) => (
                                        <div
                                            key={assignment.id}
                                            className="flex items-start gap-4 pb-4 border-b border-border last:border-0"
                                        >
                                            <div className="flex-1">
                                                <div className="flex items-center gap-2">
                                                    <span className="font-medium text-foreground">
                                                        {assignment.user.name}
                                                    </span>
                                                    <span className="text-sm text-muted-foreground">
                                                        {assignment.user.email}
                                                    </span>
                                                </div>
                                                <div className="text-sm text-muted-foreground mt-1">
                                                    Assigned: {new Date(assignment.assignedAt).toLocaleDateString()}
                                                    {assignment.unassignedAt && (
                                                        <span className="ml-2">
                                                            • Returned: {new Date(assignment.unassignedAt).toLocaleDateString()}
                                                        </span>
                                                    )}
                                                </div>
                                                {assignment.notes && (
                                                    <p className="text-sm text-foreground mt-2">{assignment.notes}</p>
                                                )}
                                            </div>
                                            {!assignment.unassignedAt && (
                                                <span className="badge-success">Current</span>
                                            )}
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>

                    {/* Sidebar */}
                    <div className="space-y-6">
                        {/* Assignment Status */}
                        <div className="card">
                            <h3 className="text-lg font-semibold text-foreground mb-4">Assignment</h3>
                            {asset.assignedTo ? (
                                <div className="space-y-3">
                                    <div>
                                        <div className="font-medium text-foreground">{asset.assignedTo.name}</div>
                                        <div className="text-sm text-muted-foreground">{asset.assignedTo.email}</div>
                                        <div className="mt-2">
                                            <span className="badge-primary">{asset.assignedTo.role}</span>
                                        </div>
                                    </div>
                                </div>
                            ) : (
                                <p className="text-sm text-muted-foreground">Not assigned to anyone</p>
                            )}
                        </div>

                        {/* QR Code */}
                        {asset.qrCode && (
                            <div className="card">
                                <h3 className="text-lg font-semibold text-foreground mb-4">QR Code</h3>
                                <div className="flex flex-col items-center space-y-3">
                                    <img
                                        src={asset.qrCode}
                                        alt={`QR Code for ${asset.name}`}
                                        className="w-48 h-48 border-2 border-border rounded-lg"
                                    />
                                    <button
                                        onClick={downloadQRCode}
                                        className="btn-secondary text-sm w-full"
                                    >
                                        📥 Download QR Code
                                    </button>
                                    <p className="text-xs text-muted-foreground text-center">
                                        Scan to view asset details
                                    </p>
                                </div>
                            </div>
                        )}

                        {/* Tags */}
                        {asset.tags && asset.tags.length > 0 && (
                            <div className="card">
                                <h3 className="text-lg font-semibold text-foreground mb-4">Tags</h3>
                                <div className="flex flex-wrap gap-2">
                                    {asset.tags.map((tag) => (
                                        <span key={tag} className="badge-primary">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        )}

                        {/* Recent Sessions */}
                        {asset.remoteSessions && asset.remoteSessions.length > 0 && (
                            <div className="card">
                                <h3 className="text-lg font-semibold text-foreground mb-4">Recent Sessions</h3>
                                <div className="space-y-3">
                                    {asset.remoteSessions.slice(0, 5).map((session) => (
                                        <div key={session.id} className="text-sm">
                                            <div className="font-medium text-foreground">{session.user.name}</div>
                                            <div className="text-muted-foreground">
                                                {new Date(session.startedAt).toLocaleDateString()}
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                </div>

                {/* Delete Modal */}
                {showDeleteModal && (
                    <div className="fixed inset-0 bg-black/50 flex items-center justify-center z-50">
                        <div className="card max-w-md w-full mx-4">
                            <h3 className="text-lg font-semibold text-foreground mb-4">Delete Asset</h3>
                            <p className="text-sm text-muted-foreground mb-6">
                                Are you sure you want to delete {asset.name}? This action cannot be undone.
                            </p>
                            <div className="flex justify-end gap-3">
                                <button
                                    onClick={() => setShowDeleteModal(false)}
                                    className="btn-secondary"
                                    disabled={deleting}
                                >
                                    Cancel
                                </button>
                                <button
                                    onClick={handleDelete}
                                    className="btn bg-red-600 text-white hover:bg-red-700"
                                    disabled={deleting}
                                >
                                    {deleting ? 'Deleting...' : 'Delete'}
                                </button>
                            </div>
                        </div>
                    </div>
                )}
            </div>
        </div>
    );
}
