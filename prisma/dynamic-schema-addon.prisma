// ============================================

// ============================================
// ENUMS
// ============================================

enum FieldType {
  STRING
  TEXT
  NUMBER
  DECIMAL
  BOOLEAN
  DATE
  DATETIME
  TIME
  JSON
  ARRAY
  SELECT
  MULTI_SELECT
  ASSET_REF
  USER_REF
  FILE
  IMAGE
  VIDEO
  URL
  EMAIL
  PHONE
  IP_ADDRESS
  MAC_ADDRESS
  COLOR
  CURRENCY
}

enum ActionType {
  POWER
  NETWORK
  MAINTENANCE
  MONITORING
  DATA
  SECURITY
  CUSTOM
}

enum HandlerType {
  API
  SCRIPT
  WEBHOOK
  REMOTE_COMMAND
  MANUAL
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMEOUT
}

enum RelationshipType {
  CONTAINS
  PART_OF
  INSTALLED_ON
  HOSTED_ON
  DEPENDS_ON
  LOCATED_IN
  CONNECTED_TO
  LICENSED_TO
  COMPONENT_OF
  DEPLOYED_ON
  MANAGED_BY
  CUSTOM
}

// ============================================
// CATEGORY SYSTEM
// ============================================

model AssetCategory {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String?        @db.Text
  icon String?
  
  // Hierarchy - parent will be  NULL for root categories (Physical, Digital)
  parentId        String?
  parent          AssetCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children        AssetCategory[] @relation("CategoryHierarchy")
  
  // Asset type reference (Physical or Digital)  
  assetTypeValue  AssetType      // Using existing AssetType enum
  
  // Configuration
  allowsChildren  Boolean        @default(true)
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  metadata        Json?
  
  // Relationships
  fieldDefinitions AssetFieldDefinition[]
  actionDefinitions AssetActionDefinition[]
  assets          Asset[]        @relation("AssetCategory")
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@index([parentId])
  @@index([slug])
  @@index([assetTypeValue])
}

// ============================================
// DYNAMIC FIELDS
// ============================================

model AssetFieldDefinition {
  id              String        @id @default(cuid())
  
  // Field metadata
  name            String
  label           String
  slug            String
  description     String?       @db.Text
  fieldType       FieldType
  
  // Category
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Validation
  isRequired      Boolean       @default(false)
  isUnique        Boolean       @default(false)
  isInherited     Boolean       @default(false)
  defaultValue    String?       @db.Text
  validationRules Json?
  
  // UI
  sortOrder       Int           @default(0)
  isVisible       Boolean       @default(true)
  isSearchable    Boolean       @default(false)
  group           String?
  placeholder     String?
  helpText        String?       @db.Text
  
  // Values
  fieldValues     AssetFieldValue[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([fieldType])
}

model AssetFieldValue {
  id                   String               @id @default(cuid())
  
  // References
  assetId              String
  asset                Asset                @relation("AssetFieldValues", fields: [assetId], references: [id], onDelete: Cascade)
  fieldDefinitionId    String 
  fieldDefinition      AssetFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  
  // Values (polymorphic - use appropriate column based on field type)
  valueString          String?              @db.Text
  valueNumber          Float?
  valueBoolean         Boolean?
  valueDate            DateTime?
  valueJson            Json?
  
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  
  @@unique([assetId, fieldDefinitionId])
  @@index([assetId])
  @@index([fieldDefinitionId])
}

// ============================================
// DYNAMIC ACTIONS
// ============================================

model AssetActionDefinition {
  id              String        @id @default(cuid())
  
  // Action metadata
  name            String
  label           String
  slug            String
  description     String?       @db.Text
  icon            String?
  
  // Category
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  // Action configuration
  actionType      ActionType
  isDestructive   Boolean       @default(false)
  requiresConfirmation Boolean   @default(false)
  estimatedDuration Int?
  
  // Execution
  handlerType     HandlerType
  handlerConfig   Json?
  parameters      Json?
  
  // UI
  sortOrder       Int           @default(0)
  isVisible       Boolean       @default(true)
  buttonColor     String?
  
  // History
  executions      AssetActionExecution[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([actionType])
}

model AssetActionExecution {
  id                     String                 @id @default(cuid())
  
  // References
  assetId                String
  asset                  Asset                  @relation("AssetActionExecutions", fields: [assetId], references: [id])
  actionDefinitionId     String
  actionDefinition       AssetActionDefinition  @relation(fields: [actionDefinitionId], references: [id])
  userId                 String?
  user                   User?                  @relation("UserActionExecutions", fields: [userId], references: [id])
  
  // Execution details
  status                 ExecutionStatus        @default(PENDING)
  startedAt              DateTime               @default(now())
  completedAt            DateTime?
  duration               Int?
  
  // Input/Output
  parameters             Json?
  result                 Json?
  errorMessage           String?                @db.Text
  logs                   String?                @db.Text
  
  // Metadata
  triggerType            String?
  metadata               Json?
  
  @@index([assetId])
  @@index([actionDefinitionId])
  @@index([userId])
  @@index([status])
  @@index([startedAt])
}

// ============================================
// ASSET RELATIONSHIPS
// ============================================

model AssetRelationship {
  id              String           @id @default(cuid())
  
  // The relationship
  parentAssetId   String
  childAssetId    String
  relationshipType RelationshipType
  
  // Metadata
  quantity        Int?
  position        String?
  metadata        Json?
  
  // Relationships
  parentAsset     Asset            @relation("ParentAssetRelationships", fields: [parentAssetId], references: [id], onDelete: Cascade)
  childAsset      Asset            @relation("ChildAssetRelationships", fields: [childAssetId], references: [id], onDelete: Cascade)
  
  // Audit
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?
  createdBy       User?            @relation("UserAssetRelationships", fields: [createdById], references: [id])
  
  @@unique([parentAssetId, childAssetId, relationshipType])
  @@index([parentAssetId])
  @@index([childAssetId])
  @@index([relationshipType])
}

