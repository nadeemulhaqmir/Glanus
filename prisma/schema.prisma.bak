// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  IT_STAFF
  USER
}

enum AssetType {
  HARDWARE
  SOFTWARE
}

enum HostType {
  ASSET
  PROVIDER
  HYBRID
  ON_PREMISE
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
  LOST
}

enum SessionStatus {
  ACTIVE
  ENDED
  FAILED
}

enum HardwareCategory {
  LAPTOP
  DESKTOP
  SERVER
  MOBILE_DEVICE
  TABLET
  PRINTER
  NETWORK_EQUIPMENT
  MONITOR
  PERIPHERAL
  OTHER
}

enum SoftwareCategory {
  WEB_APPLICATION
  MOBILE_APP
  DESKTOP_APP
  SAAS_SUBSCRIPTION
  DATABASE
  DEVELOPMENT_TOOL
  SECURITY_SOFTWARE
  LICENSE
  API_SERVICE
  CLOUD_STORAGE
  VIRTUAL_MACHINE
  LLM
  OTHER
}

enum LicenseType {
  PERPETUAL
  SUBSCRIPTION
  TRIAL
  OPEN_SOURCE
  FREEMIUM
  ENTERPRISE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets           Asset[]
  sessions         RemoteSession[]
  auditLogs        AuditLog[]
  aiInsights       AIInsight[]
  assetAssignments AssignmentHistory[]

  @@index([email])
}

model Asset {
  id            String      @id @default(cuid())
  assetType     AssetType   @default(HARDWARE)
  name          String
  category      String
  manufacturer  String?
  model         String?
  serialNumber  String?     @unique
  status        AssetStatus @default(AVAILABLE)
  location      String?
  description   String?     @db.Text
  purchaseDate  DateTime?
  purchaseCost  Float?
  warrantyUntil DateTime?
  tags          String[]
  qrCode        String?     @db.Text
  assignedToId  String?
  assignedTo    User?       @relation(fields: [assignedToId], references: [id])

  hardwareAsset HardwareAsset?
  softwareAsset SoftwareAsset?

  assignmentHistory AssignmentHistory[]
  remoteSessions    RemoteSession[]
  auditLogs         AuditLog[]
  aiInsights        AIInsight[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  @@index([status])
  @@index([assignedToId])
  @@index([category])
  @@index([assetType])
  @@index([deletedAt])
}

model HardwareAsset {
  id      String @id @default(cuid())
  assetId String @unique
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  category     HardwareCategory
  manufacturer String?
  model        String?
  serialNumber String?          @unique

  // Technical specifications
  processor  String?
  ram        Int? // GB
  storage    Int? // GB
  osVersion  String?
  macAddress String?
  ipAddress  String?

  // MDM fields (for future Phase 8)
  isManaged   Boolean   @default(false)
  mdmEnrolled DateTime?
  lastSeen    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([serialNumber])
  @@index([manufacturer])
}

model SoftwareAsset {
  id      String @id @default(cuid())
  assetId String @unique
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  category    SoftwareCategory
  version     String?
  vendor      String?
  licenseKey  String?          @db.Text
  licenseType LicenseType?

  // License management
  seatCount Int?
  seatsUsed Int?

  // SaaS-specific fields
  subscriptionTier     String?
  monthlyRecurringCost Float?
  renewalDate          DateTime?
  autoRenew            Boolean   @default(false)

  // Hosting relationship
  host     String?
  hostType HostType?

  // Web/Database specific
  url              String?
  sslExpiry        DateTime?
  connectionString String?   @db.Text
  databaseSize     Int? // MB

  // Installation tracking
  installedOn String[] // Asset IDs where installed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([renewalDate])
  @@index([vendor])
}

model AssignmentHistory {
  id           String    @id @default(cuid())
  assetId      String
  userId       String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  notes        String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@index([userId])
}

model RemoteSession {
  id        String        @id @default(cuid())
  assetId   String
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  status    SessionStatus @default(ACTIVE)
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  duration  Int? // in seconds

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  assetId    String?
  asset      Asset?   @relation(fields: [assetId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([assetId])
  @@index([createdAt])
}

model AIInsight {
  id          String  @id @default(cuid())
  type        String
  title       String
  description String
  severity    String?
  confidence  Float?
  metadata    Json?

  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  acknowledged Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([assetId])
  @@index([acknowledged])
}
