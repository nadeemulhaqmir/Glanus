# Environment Variables for Glanus Platform

# ============================================
# REQUIRED (always)
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/glanus"

# Authentication & Sessions
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
REDIS_URL="redis://localhost:6379"

# Security
CSRF_SECRET="your-csrf-secret-here-minimum-32-characters-change-in-production"
CRON_SECRET="your-cron-secret-change-in-production"

# ============================================
# REQUIRED (production only)
# ============================================

# System Configuration
NEXT_PUBLIC_APP_URL="https://glanus.example.com"
NEXT_PUBLIC_API_URL="https://glanus.example.com/api"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PERSONAL="price_..."
STRIPE_PRICE_TEAM="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PERSONAL="price_..."
NEXT_PUBLIC_STRIPE_PRICE_TEAM="price_..."

# Sentry Error Tracking
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""

# Seed Script (development only)
SEED_PASSWORD=""  # Override default seed password; leave empty for default

# ============================================
# OPTIONAL (with sensible defaults)
# ============================================

# Security Settings
SESSION_TIMEOUT_HOURS=24
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
CORS_ALLOWED_ORIGINS="https://app.example.com,https://api.example.com"

# OpenAI (Optional - Platform works without it)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo-preview"

# Email (SendGrid)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@glanus.com"
ALERT_FROM_EMAIL="alerts@glanus.com"

# Email (Brevo / Sendinblue — fallback when SENDGRID_API_KEY is not set)
BREVO_API_KEY=""
BREVO_FROM_EMAIL="noreply@glanus.com"
BREVO_FROM_NAME="Glanus"

# Logging & Infrastructure
LOG_LEVEL="info"
GLANUS_SSH_KEYS_PATH="/app/ssh_keys"    # Path where Agent SSH keys are stored
CONTAINER="false"                       # Set to true if running in Docker
