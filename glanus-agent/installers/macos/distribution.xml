<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>Glanus Agent</title>
    <organization>com.glanus</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true" />
    
    <!-- Define documents displayed at various steps -->
    <welcome    file="welcome.html"    mime-type="text/html" />
    <license    file="license.html"   mime-type="text/html" />
    <conclusion file="conclusion.html" mime-type="text/html" />
    
    <!-- List all component packages -->
    <pkg-ref id="com.glanus.agent"
             version="0.0.0"
             onConclusion="none">glanus-agent-component.pkg</pkg-ref>
    
    <!-- List them again here. They can now be organized
         as a hierarchy if you want. -->
    <choices-outline>
        <line choice="default">
            <line choice="com.glanus.agent"/>
        </line>
    </choices-outline>
    
    <!-- Define each choice above -->
    <choice id="default"/>
    <choice id="com.glanus.agent" visible="false">
        <pkg-ref id="com.glanus.agent"/>
    </choice>
</installer-gui-script>
